# applaunch-api/.env.example
# Copy to .env and fill in your values — never commit .env to git

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key          # Service role (server-side only)
SUPABASE_JWT_SECRET=your-jwt-secret         # From Supabase: Settings → API → JWT Secret

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0           # Local: redis://redis:6379/0 in Docker Compose

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_BUCKET_SOURCES=applaunch-sources
S3_BUCKET_ARTIFACTS=applaunch-artifacts
KMS_KEY_ARN=arn:aws:kms:us-east-1:123456789012:key/your-key-id

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development                      # development | production
API_SECRET_KEY=change-me-in-production
ALLOWED_ORIGINS=http://localhost:3000
